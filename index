<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Music, Dance, Theatre & Tutoring in Lincoln, CA | Tamraloo Studios</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Pinyon+Script&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@200;300;400;500;600;700&display=swap" rel="stylesheet">

<style>
/* ============================================================
   TAMRALOO STUDIOS — HOMEPAGE v2
   Aesthetic: Luxury Black Editorial · Performing Arts Prestige
   Platform:  Wix (Custom HTML)

   Palette:
     Ink Black:    #0a0a0a
     Off-Black:    #111111
     Panel:        #161616
     Border:       #242424
     Cream:        #f5f0ea
     Script Berry: #a41c6e
     Script Pink:  #c63d8f
     Gold:         #c9a84c
     Gold Light:   #e8c96a
     White:        #ffffff
============================================================ */

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --ink:        #0a0a0a;
  --off-black:  #111111;
  --panel:      #161616;
  --border:     #242424;
  --cream:      #f5f0ea;
  --berry:      #a41c6e;
  --magenta:    #c63d8f;
  --gold:       #c9a84c;
  --gold-lt:    #e8c96a;
  --white:      #ffffff;
  --text-dim:   rgba(255,255,255,0.5);
  --text-mid:   rgba(255,255,255,0.72);
  --text-full:  rgba(255,255,255,0.92);

  --script:     'Pinyon Script', cursive;
  --serif:      'Cormorant Garamond', Georgia, serif;
  --sans:       'Jost', sans-serif;
}

html { scroll-behavior: smooth; }

body {
  font-family: var(--sans);
  background: var(--ink);
  color: var(--text-full);
  line-height: 1.6;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* ---- NOISE GRAIN OVERLAY ---- */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
  opacity: 0.028;
  pointer-events: none;
  z-index: 9999;
}

/* ---- UTILITY ---- */
.container { max-width: 1240px; margin: 0 auto; padding: 0 40px; }

.overline {
  font-family: var(--sans);
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold);
}

.divider-line {
  width: 48px;
  height: 1px;
  background: var(--gold);
  margin: 18px 0;
}

.divider-line.center { margin: 18px auto; }

/* ---- BUTTONS ---- */
.btn-gold {
  display: inline-block;
  background: transparent;
  border: 1px solid var(--gold);
  color: var(--gold);
  font-family: var(--sans);
  font-weight: 500;
  font-size: 0.72rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  padding: 15px 40px;
  text-decoration: none;
  transition: background 0.3s, color 0.3s;
  position: relative;
  overflow: hidden;
}
.btn-gold::after {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--gold);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.3s ease;
  z-index: -1;
}
.btn-gold:hover { color: var(--ink); }
.btn-gold:hover::after { transform: scaleX(1); }

.btn-white {
  display: inline-block;
  background: transparent;
  border: 1px solid rgba(255,255,255,0.3);
  color: var(--text-mid);
  font-family: var(--sans);
  font-weight: 400;
  font-size: 0.72rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  padding: 13px 36px;
  text-decoration: none;
  transition: border-color 0.3s, color 0.3s;
}
.btn-white:hover {
  border-color: rgba(255,255,255,0.7);
  color: var(--white);
}

/* ============================================================
   HERO
============================================================ */
.hero {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  position: relative;
  overflow: hidden;
}

/* left side — deep black with fine texture */
.hero-left {
  background: var(--ink);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 120px 80px 120px 80px;
  position: relative;
  z-index: 2;
}

/* subtle radial glow */
.hero-left::before {
  content: '';
  position: absolute;
  top: 30%;
  left: -20%;
  width: 500px;
  height: 500px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(164,28,110,0.08) 0%, transparent 70%);
  pointer-events: none;
}

.hero-script {
  font-family: var(--script);
  font-size: clamp(5rem, 8vw, 8.5rem);
  line-height: 0.9;
  background: linear-gradient(135deg, var(--berry) 0%, var(--magenta) 40%, var(--gold-lt) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 8px;
  position: relative;
}

.hero-studios {
  font-family: var(--sans);
  font-weight: 200;
  font-size: 0.85rem;
  letter-spacing: 0.55em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: 48px;
  padding-left: 4px;
}

.hero-headline {
  font-family: var(--serif);
  font-size: clamp(1.9rem, 3vw, 2.8rem);
  font-weight: 300;
  font-style: italic;
  color: var(--text-full);
  line-height: 1.25;
  margin-bottom: 20px;
  max-width: 480px;
}

.hero-headline em {
  font-style: normal;
  color: var(--gold-lt);
}

.hero-body {
  font-size: 0.88rem;
  font-weight: 300;
  color: var(--text-dim);
  max-width: 400px;
  line-height: 1.85;
  margin-bottom: 48px;
  letter-spacing: 0.02em;
}

.hero-ctas {
  display: flex;
  gap: 16px;
  align-items: center;
  margin-bottom: 60px;
}

.hero-phone-link {
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--text-dim);
  text-decoration: none;
  font-size: 0.75rem;
  font-weight: 400;
  letter-spacing: 0.12em;
  transition: color 0.2s;
}
.hero-phone-link:hover { color: var(--gold-lt); }
.hero-phone-link::before {
  content: '';
  display: block;
  width: 28px;
  height: 1px;
  background: currentColor;
}

/* bottom of hero left — stat strip */
.hero-stats {
  display: flex;
  gap: 40px;
  border-top: 1px solid var(--border);
  padding-top: 36px;
}

.stat-item .stat-num {
  font-family: var(--serif);
  font-size: 2rem;
  font-weight: 400;
  color: var(--white);
  line-height: 1;
  margin-bottom: 4px;
}

.stat-item .stat-num span {
  background: linear-gradient(90deg, var(--berry), var(--magenta));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-item .stat-label {
  font-size: 0.65rem;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--text-dim);
}

/* right side — dark editorial panel */
.hero-right {
  background: var(--panel);
  border-left: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 60px;
  position: relative;
  overflow: hidden;
}

/* faint vertical rule */
.hero-right::before {
  content: '';
  position: absolute;
  top: 0;
  right: 30%;
  width: 1px;
  height: 100%;
  background: var(--border);
  opacity: 0.5;
}

/* big decorative script in background */
.hero-right::after {
  content: 'Be Your Own Star';
  font-family: var(--script);
  font-size: 5rem;
  color: rgba(255,255,255,0.025);
  position: absolute;
  top: 50px;
  left: 30px;
  right: 30px;
  line-height: 1.3;
  pointer-events: none;
  white-space: nowrap;
  overflow: hidden;
}

.hero-awards-label {
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 24px;
}

.award-row {
  border-top: 1px solid var(--border);
  padding: 18px 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.award-row:last-of-type { border-bottom: 1px solid var(--border); }

.award-name {
  font-family: var(--serif);
  font-size: 0.95rem;
  font-weight: 400;
  color: var(--text-full);
  font-style: italic;
}

.award-year {
  font-size: 0.68rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  color: var(--text-dim);
}

.hero-review-strip {
  margin-top: 40px;
  padding: 24px 28px;
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--border);
}

.review-stars {
  color: var(--gold);
  font-size: 0.75rem;
  letter-spacing: 4px;
  margin-bottom: 8px;
}

.review-quote {
  font-family: var(--serif);
  font-size: 0.95rem;
  font-style: italic;
  color: var(--text-mid);
  line-height: 1.6;
  margin-bottom: 12px;
}

.review-sig {
  font-size: 0.68rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--text-dim);
}

/* ============================================================
   THIN COLOR BAR (logo stripe, tasteful)
============================================================ */
.color-bar {
  height: 3px;
  background: linear-gradient(90deg,
    var(--berry) 0%,
    var(--magenta) 30%,
    #f3b94d 55%,
    #9dce50 80%,
    var(--berry) 100%);
  opacity: 0.7;
}

/* ============================================================
   INTRO STATEMENT
============================================================ */
.intro {
  padding: 140px 40px;
  background: var(--ink);
  text-align: center;
  position: relative;
  overflow: hidden;
}

/* faint grid lines */
.intro::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size: 80px 80px;
  pointer-events: none;
}

.intro-inner {
  max-width: 800px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

.intro-script {
  font-family: var(--script);
  font-size: clamp(2.5rem, 5vw, 4rem);
  background: linear-gradient(135deg, var(--berry), var(--magenta));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 36px;
  display: block;
}

.intro h2 {
  font-family: var(--serif);
  font-size: clamp(2rem, 4vw, 3.4rem);
  font-weight: 300;
  line-height: 1.2;
  color: var(--white);
  margin-bottom: 28px;
  letter-spacing: -0.01em;
}

.intro h2 em {
  font-style: italic;
  color: var(--gold-lt);
}

.intro-lead {
  font-size: 0.9rem;
  font-weight: 300;
  color: var(--text-dim);
  line-height: 1.9;
  max-width: 600px;
  margin: 0 auto 48px;
  letter-spacing: 0.02em;
}

/* ============================================================
   DISCIPLINES — ASYMMETRIC EDITORIAL GRID
============================================================ */
.disciplines {
  background: var(--off-black);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 0;
}

.disciplines-header {
  max-width: 1240px;
  margin: 0 auto;
  padding: 80px 40px 60px;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.disciplines-header-left h2 {
  font-family: var(--serif);
  font-size: clamp(2rem, 3.5vw, 3rem);
  font-weight: 300;
  color: var(--white);
  line-height: 1.15;
}

.disciplines-header-left h2 em {
  font-style: italic;
  color: var(--gold-lt);
}

.disciplines-header-right {
  font-size: 0.82rem;
  font-weight: 300;
  color: var(--text-dim);
  max-width: 280px;
  text-align: right;
  line-height: 1.7;
}

/* horizontal scroll cards */
.disciplines-track {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border-top: 1px solid var(--border);
}

.discipline-card {
  border-right: 1px solid var(--border);
  padding: 52px 44px 60px;
  text-decoration: none;
  display: block;
  position: relative;
  overflow: hidden;
  transition: background 0.4s;
  cursor: pointer;
}
.discipline-card:last-child { border-right: none; }

/* hover fill from bottom */
.discipline-card::before {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 0;
  transition: height 0.4s ease;
}

.discipline-card:hover::before { height: 100%; }

/* color variants */
.discipline-card.music::before     { background: rgba(164,28,110,0.06); }
.discipline-card.dance::before     { background: rgba(243,185,77,0.05); }
.discipline-card.theatre::before   { background: rgba(157,206,80,0.05); }
.discipline-card.tutoring::before  { background: rgba(111,28,80,0.08); }

.discipline-card:hover { background: rgba(255,255,255,0.02); }

.disc-number {
  font-family: var(--serif);
  font-size: 3.5rem;
  font-weight: 300;
  color: rgba(255,255,255,0.06);
  position: absolute;
  top: 24px;
  right: 28px;
  line-height: 1;
}

.disc-icon {
  font-size: 1.6rem;
  margin-bottom: 28px;
  display: block;
}

.disc-label {
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  margin-bottom: 16px;
}

.music    .disc-label { color: var(--berry); }
.dance    .disc-label { color: #c9a84c; }
.theatre  .disc-label { color: #9dce50; }
.tutoring .disc-label { color: var(--magenta); }

.disc-title {
  font-family: var(--serif);
  font-size: 1.5rem;
  font-weight: 400;
  color: var(--white);
  margin-bottom: 16px;
  line-height: 1.2;
  font-style: italic;
}

.disc-body {
  font-size: 0.8rem;
  font-weight: 300;
  color: var(--text-dim);
  line-height: 1.8;
  margin-bottom: 32px;
}

.disc-offerings {
  list-style: none;
  margin-bottom: 36px;
}

.disc-offerings li {
  font-size: 0.72rem;
  font-weight: 400;
  color: var(--text-dim);
  letter-spacing: 0.08em;
  padding: 6px 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  display: flex;
  align-items: center;
  gap: 10px;
}
.disc-offerings li::before {
  content: '—';
  color: var(--gold);
  opacity: 0.5;
  font-size: 0.65rem;
}
.disc-offerings li:last-child { border-bottom: none; }

.disc-link {
  font-size: 0.68rem;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  text-decoration: none;
  color: var(--gold);
  display: flex;
  align-items: center;
  gap: 10px;
  transition: gap 0.2s;
}
.disc-link::after { content: '→'; }
.disc-link:hover { gap: 16px; }

/* ============================================================
   FREE LESSON FULL-WIDTH BAND
============================================================ */
.cta-band {
  padding: 160px 40px;
  text-align: center;
  background: var(--ink);
  position: relative;
  overflow: hidden;
}

/* big script watermark */
.cta-band::before {
  content: 'Begin';
  font-family: var(--script);
  font-size: 30vw;
  color: rgba(255,255,255,0.018);
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
  white-space: nowrap;
}

/* gold radial glow */
.cta-band::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600px;
  height: 600px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(201,168,76,0.06) 0%, transparent 70%);
  pointer-events: none;
}

.cta-band-inner {
  position: relative;
  z-index: 1;
  max-width: 680px;
  margin: 0 auto;
}

.cta-script {
  font-family: var(--script);
  font-size: clamp(3rem, 7vw, 6rem);
  display: block;
  margin-bottom: 12px;
  background: linear-gradient(135deg, var(--berry) 0%, var(--magenta) 50%, var(--gold-lt) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.cta-band h2 {
  font-family: var(--serif);
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  font-weight: 300;
  color: var(--white);
  margin-bottom: 20px;
  letter-spacing: -0.01em;
}

.cta-band p {
  font-size: 0.87rem;
  font-weight: 300;
  color: var(--text-dim);
  line-height: 1.85;
  max-width: 480px;
  margin: 0 auto 48px;
}

.cta-note {
  margin-top: 24px;
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  color: var(--text-dim);
}
.cta-note a {
  color: var(--text-dim);
  text-decoration: none;
  border-bottom: 1px solid rgba(255,255,255,0.15);
  transition: color 0.2s, border-color 0.2s;
}
.cta-note a:hover { color: var(--gold); border-color: var(--gold); }

/* ============================================================
   TAMIE — ARTISTIC DIRECTOR PROFILE
============================================================ */
.tamie-section {
  background: var(--panel);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.tamie-inner {
  max-width: 1240px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 660px;
}

.tamie-content {
  padding: 100px 80px 100px 40px;
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.tamie-content h2 {
  font-family: var(--serif);
  font-size: clamp(1.8rem, 3vw, 2.6rem);
  font-weight: 300;
  font-style: italic;
  color: var(--white);
  margin-bottom: 28px;
  line-height: 1.2;
}

.tamie-name-script {
  font-family: var(--script);
  font-size: 2.8rem;
  background: linear-gradient(90deg, var(--berry), var(--magenta));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
  margin-bottom: 4px;
}

.tamie-title-line {
  font-size: 0.68rem;
  font-weight: 500;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: 36px;
}

.tamie-body {
  font-size: 0.87rem;
  font-weight: 300;
  color: var(--text-dim);
  line-height: 1.9;
  max-width: 520px;
  margin-bottom: 20px;
}

.charter-callout {
  margin-top: 32px;
  padding: 20px 24px;
  border: 1px solid var(--border);
  border-left: 3px solid var(--gold);
  font-size: 0.82rem;
  font-weight: 300;
  color: var(--text-mid);
  line-height: 1.7;
  margin-bottom: 36px;
}

.charter-callout strong {
  display: block;
  color: var(--gold);
  font-weight: 600;
  font-size: 0.68rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 8px;
}

/* credentials side */
.tamie-creds {
  padding: 100px 40px 100px 80px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.creds-label {
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 28px;
}

.cred-item {
  border-bottom: 1px solid var(--border);
  padding: 18px 0;
  display: grid;
  grid-template-columns: 20px 1fr;
  gap: 16px;
  align-items: start;
}
.cred-item:first-of-type { border-top: 1px solid var(--border); }

.cred-bullet {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--gold);
  margin-top: 6px;
  flex-shrink: 0;
}

.cred-text {
  font-family: var(--serif);
  font-size: 0.97rem;
  font-weight: 400;
  font-style: italic;
  color: var(--text-mid);
  line-height: 1.4;
}

/* ============================================================
   TESTIMONIALS — MAGAZINE PULL-QUOTE STYLE
============================================================ */
.testimonials {
  background: var(--ink);
  padding: 140px 40px;
  position: relative;
  overflow: hidden;
}

.testimonials::before {
  content: '"';
  font-family: var(--script);
  font-size: 40vw;
  color: rgba(164,28,110,0.04);
  position: absolute;
  top: -10%;
  left: -5%;
  line-height: 1;
  pointer-events: none;
}

.testimonials-header {
  max-width: 1240px;
  margin: 0 auto 80px;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.testimonials-header h2 {
